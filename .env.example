# WalletConnect Project ID
# Get your project ID from: https://cloud.walletconnect.com/
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Optional: Override RiseChain RPC URL (default: https://testnet.riselabs.xyz/http)
# VITE_RISECHAIN_RPC_URL=https://testnet.riselabs.xyz/http

# Alchemy API Key (Recommended for production)
# Get your API key from: https://dashboard.alchemy.com/
VITE_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Optional: CoinGecko API (Free tier works, pro tier for better rate limits)
# Get your API key from: https://www.coingecko.com/en/api/pricing
VITE_COINGECKO_API_KEY=

# Optional: Infura API Key (Fallback RPC provider)
# Get your API key from: https://infura.io/
VITE_INFURA_API_KEY=
